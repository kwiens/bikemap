# Copy this file to .env.local and fill in the values.
#
# Mapbox public access token — required for the map to render.
# It is a public token (starts with "pk.") and is exposed to the browser;
# scope it to your domains in the Mapbox dashboard.
# Create one at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: default city when the hostname is not listed below.
# Valid values: chattanooga, bend
NEXT_PUBLIC_CITY_ID=chattanooga

# Optional: host-to-city routing for one Vercel project serving multiple domains.
# This value is public and bundled into the browser app.
NEXT_PUBLIC_CITY_HOST_MAP='{"bikechatt.com":"chattanooga","www.bikechatt.com":"chattanooga","ridebend.org":"bend","www.ridebend.org":"bend"}'
